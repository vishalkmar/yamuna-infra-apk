import React from 'react';
import { View, Text, StyleSheet, KeyboardAvoidingView, Platform } from 'react-native';
import { useDispatch, useSelector } from 'react-redux';
import { useForm, Controller } from 'react-hook-form';
import { yupResolver } from '@hookform/resolvers/yup';

import ScreenContainer from '../../components/ScreenContainer';
import Input from '../../components/Input';
import Button from '../../components/Button';
import { loginSchema } from '../../utils/validation';
import { sendOtp, setMobile } from '../../store/slices/authSlice';
import { showToast } from '../../utils/toastConfig';
import { palette, spacing, typography } from '../../theme';

export default function LoginScreen({ navigation }) {
  const dispatch = useDispatch();
  const loading = useSelector(s => s.auth.loading);

  const { control, handleSubmit, formState: { errors } } = useForm({
    resolver: yupResolver(loginSchema),
    defaultValues: { mobileNumber: '' },
  });

  const onSubmit = async data => {
    try {
      await dispatch(sendOtp(data.mobileNumber)).unwrap();
      dispatch(setMobile(data.mobileNumber));
      showToast('success', 'OTP Sent', `OTP sent to +91 ${data.mobileNumber}`);
      navigation.navigate('OTP');
    } catch (e) {
      showToast('error', 'Failed', 'Could not send OTP. Please try again.');
    }
  };

  return (
    <ScreenContainer scroll={false}>
      <KeyboardAvoidingView
        behavior={Platform.OS === 'ios' ? 'padding' : undefined}
        style={styles.flex}
      >
        <View style={styles.header}>
          <View style={styles.logoBadge}>
            <Text style={styles.logoText}>श्री</Text>
          </View>
          <Text style={typography.h1}>Welcome to Yamuna Infra</Text>
          <Text style={[typography.bodyMuted, { marginTop: 6 }]}>
            Log in with your registered mobile number to access your booking.
          </Text>
        </View>

        <View style={styles.form}>
          <Controller
            control={control}
            name="mobileNumber"
            render={({ field: { value, onChange } }) => (
              <Input
                label="Mobile Number"
                placeholder="+91 9XXXXXXXXX"
                value={value}
                onChangeText={onChange}
                keyboardType="phone-pad"
                maxLength={10}
                error={errors.mobileNumber?.message}
              />
            )}
          />

          <Button
            title="Send OTP"
            onPress={handleSubmit(onSubmit)}
            loading={loading}
          />

          <Text style={styles.hint}>
            We'll send a 6-digit verification code via SMS. Use {' '}
            <Text style={{ fontWeight: '700' }}>123456</Text> for demo.
          </Text>
        </View>
      </KeyboardAvoidingView>
    </ScreenContainer>
  );
}

const styles = StyleSheet.create({
  flex: { flex: 1 },
  header: { marginTop: spacing.xl, marginBottom: spacing.xl },
  logoBadge: {
    width: 64, height: 64, borderRadius: 16,
    backgroundColor: palette.primary,
    alignItems: 'center', justifyContent: 'center',
    marginBottom: spacing.lg,
  },
  logoText: { color: '#fff', fontSize: 24, fontWeight: '800' },
  form: { marginTop: spacing.md },
  hint: { marginTop: spacing.md, color: palette.textMuted, fontSize: 12, lineHeight: 18 },
});
