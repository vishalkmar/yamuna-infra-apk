import React from 'react';
import { View, Text, StyleSheet, ActivityIndicator } from 'react-native';
import { palette, spacing } from '../../theme';

// Pure presentational splash. RootNavigator shows this while booting, then
// swaps to AuthStack / MainDrawer based on auth state.
export default function SplashScreen() {
  return (
    <View style={styles.container}>
      <View style={styles.logoWrap}>
        <Text style={styles.logo}>श्री</Text>
      </View>
      <Text style={styles.title}>Yamuna Infra</Text>
      <Text style={styles.tagline}>Customer Experience</Text>
      <ActivityIndicator color="#fff" style={{ marginTop: spacing.xl }} />
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    alignItems: 'center',
    justifyContent: 'center',
    backgroundColor: palette.primary,
  },
  logoWrap: {
    width: 96, height: 96, borderRadius: 24,
    backgroundColor: '#fff',
    alignItems: 'center', justifyContent: 'center',
    marginBottom: spacing.lg,
  },
  logo: { fontSize: 38, fontWeight: '800', color: palette.primary },
  title: { fontSize: 28, fontWeight: '800', color: '#fff', marginTop: spacing.sm },
  tagline: { fontSize: 14, color: '#DBE3FF', marginTop: 4 },
});
