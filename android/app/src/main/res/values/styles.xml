<resources>

    <!-- Base application theme. The app is designed light; force light so the
         device's dark mode can't force-dark / invert colours (which made the
         OTP input text invisible and the whole UI render dark). -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

</resources>
